# ============================================================================
#  Copy this file to ".env" before running:  cp .env.example .env
#  These are FICTIONAL lab credentials.  They are safe to publish because the
#  stack only ever runs on localhost / an isolated Docker network.
#
#  SQL Server requires a strong SA password: >= 8 chars including upper-case,
#  lower-case, digits and symbols.  Avoid single quotes ' in these values.
# ============================================================================

# SA (sysadmin) password for the SQL Server instance.
SA_PASSWORD=Str0ng_SA_Passw0rd!

# Password for the over-privileged application login "webapp".
WEBAPP_PASSWORD=W3bApp_Passw0rd!
