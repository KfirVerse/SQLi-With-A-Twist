@page "/reports"
@model SqliRceLab.Pages.ReportsModel
@{
    ViewData["Title"] = "Reports";
    ViewData["ActivePage"] = "reports";

    var devices = new (string Name, int Pct)[] { ("Mobile", 58), ("Desktop", 33), ("Tablet", 9) };
    var creatives = new (string Name, string Fmt, double Ctr, decimal Cpc)[]
    {
        ("aurora_hero_1200x628", "Display", 3.41, 0.74m),
        ("summer_splash_story",  "Social",  2.88, 0.61m),
        ("peak_fitness_15s",     "Video",   1.92, 0.95m),
        ("nightowl_audio_square","Social",  2.55, 0.68m),
        ("meridian_reveal_carou","Social",  3.02, 0.72m),
    };
}

<style>
    .mix { padding:10px 18px 16px; }
    .mix .r { padding:10px 0; border-bottom:1px solid var(--line); }
    .mix .r:last-child { border-bottom:0; }
    .mix .top { display:flex; justify-content:space-between; margin-bottom:7px; font-size:13px; }
    .mix .track { height:8px; background:var(--panel2); border-radius:999px; overflow:hidden; }
    .mix .fill { height:100%; background:linear-gradient(90deg,var(--brand),#9b7bff); border-radius:999px; }
    .mix .fill.g { background:linear-gradient(90deg,var(--green),#5b8cff); }
</style>

<div class="row2">
    <div class="panel">
        <div class="hd"><h2>Spend by channel</h2><span class="sub">last 30 days</span></div>
        <div class="mix">
            @foreach (var ch in DemoData.Channels)
            {
                <div class="r">
                    <div class="top"><span>@ch.Name</span><span class="muted">$@ch.Spend.ToString("N0") · @ch.Pct%</span></div>
                    <div class="track"><div class="fill" style="width:@(ch.Pct)%"></div></div>
                </div>
            }
        </div>
    </div>

    <div class="panel">
        <div class="hd"><h2>Impressions by device</h2></div>
        <div class="mix">
            @foreach (var d in devices)
            {
                <div class="r">
                    <div class="top"><span>@d.Name</span><span class="muted">@d.Pct%</span></div>
                    <div class="track"><div class="fill g" style="width:@(d.Pct)%"></div></div>
                </div>
            }
        </div>
    </div>
</div>

<div class="panel mt16">
    <div class="hd"><h2>Top creatives</h2><span class="sub">by click-through rate</span></div>
    <div class="bd">
        <table>
            <thead>
                <tr><th>Creative</th><th>Format</th><th class="num">CTR</th><th class="num">Avg CPC</th></tr>
            </thead>
            <tbody>
                @foreach (var cr in creatives)
                {
                    <tr>
                        <td>@cr.Name</td>
                        <td>@cr.Fmt</td>
                        <td class="num">@cr.Ctr.ToString("0.00")%</td>
                        <td class="num">$@cr.Cpc.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
